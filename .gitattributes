# Normalize line endings on commit, check out native on each platform
* text=auto eol=lf

# Scripts and config keep LF
*.ps1   text eol=lf
*.psd1  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.json  text eol=lf

# Treat these as binary (never normalize / diff)
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary

# Collapse generated/noise files in diffs
*.lock  linguist-generated=true
